# build.env — Machine-specific paths for build and flash.
# This file is sourced by setup_env.sh and build.sh.
# Copy build.env.example to build.env and adjust for your machine.
# This file is gitignored — do NOT commit it.

# Zephyr workspace (where west init was run)
# Default: sibling directory ../zephyrproject relative to this project
# ZEPHYR_WORKSPACE=/home/arun/zephyrproject

# Zephyr SDK installation directory
# Default: sibling directory ../zephyr-sdk-0.17.0 relative to this project
# ZEPHYR_SDK_DIR=/home/arun/zephyr-sdk-0.17.0

# Windows OpenOCD directory (for WSL → Windows flashing)
OPENOCD_DIR="C:/Users/arunj/.pico-sdk/openocd/0.12.0+dev"

# Windows directory to copy firmware hex for flashing
WINDOWS_FLASH_DIR="/mnt/c/nrf_recovery"
